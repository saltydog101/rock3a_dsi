/dts-v1/;
/plugin/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include <dt-bindings/clock/rk3568-cru.h>
#include <dt-bindings/soc/rockchip,vop2.h>

/ {
	metadata {
		title = "Enable BTT Pi TFT50 DSI Display";
		compatible = "radxa,rock-3a";
		category = "display";
		exclusive = "dsi1";
		description = "Enable BTT Pi TFT50 5-inch DSI display on DSI1.";
	};
};

/* Power regulator for the DSI connector */
&{/} {
	vcc_mipi: vcc-mipi {
		compatible = "regulator-fixed";
		status = "okay";
		regulator-name = "vcc_mipi";
		regulator-boot-on;
		regulator-always-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		enable-active-high;
		gpio = <&gpio3 RK_PC0 GPIO_ACTIVE_HIGH>;
	};
};

/* Enable DSI1 DPHY */
&dsi_dphy1 {
	status = "okay";
};

/* Route VOP video port 1 to DSI1 */
&vp1 {
	#address-cells = <1>;
	#size-cells = <0>;

	vp1_out_dsi1: endpoint@ROCKCHIP_VOP2_EP_MIPI1 {
		reg = <ROCKCHIP_VOP2_EP_MIPI1>;
		remote-endpoint = <&dsi1_in_vp1>;
	};
};

/* DSI1 input from VOP VP1 */
&dsi1_in {
	#address-cells = <1>;
	#size-cells = <0>;

	dsi1_in_vp1: endpoint@0 {
		reg = <0>;
		remote-endpoint = <&vp1_out_dsi1>;
	};
};

/* DSI1 output to panel */
&dsi1_out {
	#address-cells = <1>;
	#size-cells = <0>;

	dsi1_out_panel: endpoint@0 {
		reg = <0>;
		remote-endpoint = <&panel_dsi_port>;
	};
};

/* Enable DSI1 controller */
&dsi1 {
	status = "okay";
	rockchip,lane-rate = <696>;
};

/* I2C3 — panel MCU + touch */
&i2c3 {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	btt_panel: lcd@45 {
		compatible = "raspberrypi,7inch-touchscreen-panel";
		reg = <0x45>;

		port {
			panel_dsi_port: endpoint {
				remote-endpoint = <&dsi1_out_panel>;
			};
		};
	};

	touchscreen@38 {
		compatible = "goodix,gt911";
		reg = <0x38>;
		/* No IRQ GPIO — driver falls back to polling mode */
		touchscreen-size-x = <800>;
		touchscreen-size-y = <480>;
	};
};
